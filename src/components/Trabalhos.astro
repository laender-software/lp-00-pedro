---
const trabalhos = [
  {
    nome: "Dra. Raquel Cosso",
    especialidade: "Endocrinologia · Belo Horizonte",
    url: "https://draraquelcosso.com.br",
    urlDisplay: "draraquelcosso.com.br",
    imagem: "/images/trabalhos/raquel.webp",
    alt: "Site da Dra. Raquel Cosso — endocrinologista em Belo Horizonte",
  },
  {
    nome: "Nyres Edim",
    especialidade: "Terapia Pathwork® · Belo Horizonte",
    url: "https://nyresedim.com.br",
    urlDisplay: "nyresedim.com.br",
    imagem: "/images/trabalhos/nyres.webp",
    alt: "Site da Nyres Edim — terapeuta Pathwork em Belo Horizonte",
  },
];
---

<section id="trabalhos" class="py-20 md:py-28 bg-white reveal">
  <div class="mx-auto max-w-5xl px-6">
    <span class="text-sm font-semibold uppercase tracking-widest text-accent">Trabalhos recentes</span>
    <h2 class="mt-4 font-serif text-3xl md:text-4xl font-bold text-text leading-tight">
      Sites que já estão no ar
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 stagger">
      {trabalhos.map((t) => (
        <a
          href={t.url}
          target="_blank"
          rel="noopener noreferrer"
          class="trabalho-card group bg-white rounded-2xl border border-border overflow-hidden card-lift reveal"
          aria-label={`Abrir ${t.nome} em nova aba`}
        >
          <div class="relative aspect-[16/10] overflow-hidden bg-bg-alt">
            <img
              src={t.imagem}
              alt={t.alt}
              loading="lazy"
              decoding="async"
              width="1200"
              height="750"
              class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 ease-out group-hover:scale-[1.03]"
            />
            <div class="absolute inset-0 bg-linear-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400"></div>
            <span class="absolute bottom-4 right-4 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/95 backdrop-blur text-brand text-xs font-semibold opacity-0 group-hover:opacity-100 transition-all duration-400 translate-y-2 group-hover:translate-y-0 shadow-lg">
              Visitar
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </span>
          </div>

          <div class="p-5 md:p-6">
            <h3 class="font-serif text-xl font-bold text-text leading-snug">{t.nome}</h3>
            <p class="mt-1 text-sm text-muted">{t.especialidade}</p>
            <p class="mt-3 text-xs font-mono text-brand/80 tracking-tight">{t.urlDisplay}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .trabalho-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
</style>
